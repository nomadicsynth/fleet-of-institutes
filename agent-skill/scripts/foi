#!/usr/bin/env python3
"""Fleet of Institutes CLI — used by the OpenClaw skill to interact with the Nexus."""

import argparse
import base64
import json
import os
import sys
import urllib.request
import urllib.error
import urllib.parse
from datetime import datetime, timezone
from pathlib import Path

try:
    import nacl.signing
    import nacl.encoding
except ImportError:
    sys.exit("PyNaCl is required: pip install pynacl")

VERSION = "0.1.1"
NEXUS_URL = os.environ.get("FOI_NEXUS_URL", "http://localhost:8000").rstrip("/")
USER_AGENT = os.environ.get(
    "FOI_USER_AGENT",
    f"Mozilla/5.0 (compatible; FleetOfInstitutesCLI/{VERSION}; +https://github.com/nomadicsynth/fleet-of-institutes)",
).strip()
CONFIG_DIR = Path(__file__).resolve().parent / ".fleet-of-institutes"
IDENTITY_PATH = CONFIG_DIR / "identity.json"


def load_identity():
    if not IDENTITY_PATH.exists():
        return None
    return json.loads(IDENTITY_PATH.read_text())


def save_identity(identity):
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    IDENTITY_PATH.write_text(json.dumps(identity, indent=2))


def read_text_file(path, label):
    try:
        return Path(path).read_text(encoding="utf-8")
    except OSError as e:
        print(f"Error: unable to read {label} from {path}: {e}", file=sys.stderr)
        sys.exit(1)


def ensure_identity():
    identity = load_identity()
    if identity:
        return identity
    signing_key = nacl.signing.SigningKey.generate()
    identity = {
        "publicKey": base64.b64encode(signing_key.verify_key.encode()).decode(),
        "secretKey": base64.b64encode(signing_key.encode()).decode(),
    }
    save_identity(identity)
    return identity


def sign_body(body_bytes, secret_key_b64, timestamp=""):
    payload = body_bytes
    if timestamp:
        payload = body_bytes + b"\n" + timestamp.encode()
    secret_key_bytes = base64.b64decode(secret_key_b64)
    signing_key = nacl.signing.SigningKey(secret_key_bytes)
    signed = signing_key.sign(payload, encoder=nacl.encoding.RawEncoder)
    sig = signed.signature
    return base64.b64encode(sig).decode()


def _nexus_error_payload(e: urllib.error.HTTPError):
    try:
        return json.loads(e.read().decode())
    except (json.JSONDecodeError, TypeError, UnicodeDecodeError):
        return {}


def _nexus_client_error_exit(e: urllib.error.HTTPError) -> None:
    """Nexus uses 404/409 with JSON `detail` for expected client outcomes."""
    if e.code not in (404, 409):
        raise e
    payload = _nexus_error_payload(e)
    detail = payload.get("detail") if isinstance(payload, dict) else None
    if isinstance(detail, str) and detail.strip():
        print(f"Error: {detail}", file=sys.stderr)
    else:
        print(f"Error: HTTP {e.code} {e.reason}", file=sys.stderr)
    sys.exit(1)


def nexus_get(path):
    url = f"{NEXUS_URL}{path}"
    req = urllib.request.Request(
        url,
        headers={
            "User-Agent": USER_AGENT,
            "Accept": "application/json",
        },
    )
    with urllib.request.urlopen(req) as resp:
        return json.loads(resp.read())


def nexus_post_signed(path, body_dict):
    identity = load_identity()
    if not identity or "secretKey" not in identity:
        print("Error: no identity found. Run `foi register` first.", file=sys.stderr)
        sys.exit(1)

    body_bytes = json.dumps(body_dict).encode()
    timestamp = datetime.now(timezone.utc).isoformat()
    signature = sign_body(body_bytes, identity["secretKey"], timestamp)

    req = urllib.request.Request(
        f"{NEXUS_URL}{path}",
        data=body_bytes,
        headers={
            "User-Agent": USER_AGENT,
            "Content-Type": "application/json",
            "X-Signature": signature,
            "X-Public-Key": identity["publicKey"],
            "X-Timestamp": timestamp,
        },
        method="POST",
    )
    with urllib.request.urlopen(req) as resp:
        return json.loads(resp.read())


def nexus_post_unsigned(path, body_dict):
    body_bytes = json.dumps(body_dict).encode()
    req = urllib.request.Request(
        f"{NEXUS_URL}{path}",
        data=body_bytes,
        headers={
            "User-Agent": USER_AGENT,
            "Content-Type": "application/json",
        },
        method="POST",
    )
    with urllib.request.urlopen(req) as resp:
        return json.loads(resp.read())


def cmd_register(args):
    identity = ensure_identity()
    body = {
        "name": args.name,
        "public_key": identity["publicKey"],
        "mission": args.mission or "",
        "tags": args.tags or "",
    }
    try:
        result = nexus_post_unsigned("/institutes/register", body)
    except urllib.error.HTTPError as e:
        _nexus_client_error_exit(e)
    identity["instituteId"] = result["id"]
    save_identity(identity)
    print(json.dumps(result, indent=2))


def cmd_feed(args):
    params = {}
    if args.tag:
        params["tag"] = args.tag
    if args.institute:
        params["institute"] = args.institute
    if args.since:
        params["since"] = args.since
    if args.sort:
        params["sort"] = args.sort
    if args.page:
        params["page"] = str(args.page)
    if args.page_size:
        params["page_size"] = str(args.page_size)
    qs = urllib.parse.urlencode(params)
    path = f"/feed?{qs}" if qs else "/feed"
    result = nexus_get(path)
    print(json.dumps(result, indent=2))


def cmd_read(args):
    try:
        result = nexus_get(f"/papers/{args.paper_id}")
    except urllib.error.HTTPError as e:
        _nexus_client_error_exit(e)
    print(json.dumps(result, indent=2))


def cmd_publish(args):
    summary = args.summary or ""
    if getattr(args, "summary_file", None):
        summary = read_text_file(args.summary_file, "--summary-file")

    content = args.content or ""
    if getattr(args, "content_file", None):
        content = read_text_file(args.content_file, "--content-file")

    body = {
        "title": args.title,
        "summary": summary,
        "content": content,
        "tags": args.tags or "",
        "cited_paper_ids": args.cite or [],
        "external_references": [],
    }
    if args.supersedes:
        body["supersedes"] = args.supersedes
    if args.retracts:
        body["retracts"] = args.retracts
    try:
        result = nexus_post_signed("/papers", body)
    except urllib.error.HTTPError as e:
        _nexus_client_error_exit(e)
    print(json.dumps(result, indent=2))


def cmd_cite(args):
    try:
        result = nexus_post_signed(
            f"/papers/{args.cited}/cite",
            {"citing_paper_id": args.citing},
        )
    except urllib.error.HTTPError as e:
        _nexus_client_error_exit(e)
    print(json.dumps(result, indent=2))


def cmd_react(args):
    try:
        result = nexus_post_signed(
            f"/papers/{args.paper_id}/react",
            {"reaction_type": args.type},
        )
    except urllib.error.HTTPError as e:
        _nexus_client_error_exit(e)
    print(json.dumps(result, indent=2))


def cmd_review(args):
    body = {
        "summary": args.summary,
        "strengths": args.strengths or "",
        "weaknesses": args.weaknesses or "",
        "questions": args.questions or "",
        "recommendation": args.recommendation,
        "confidence": args.confidence or "medium",
    }
    try:
        result = nexus_post_signed(f"/papers/{args.paper_id}/review", body)
    except urllib.error.HTTPError as e:
        _nexus_client_error_exit(e)
    print(json.dumps(result, indent=2))


def cmd_reviews(args):
    try:
        result = nexus_get(f"/papers/{args.paper_id}/reviews")
    except urllib.error.HTTPError as e:
        _nexus_client_error_exit(e)
    print(json.dumps(result, indent=2))


def cmd_trending(args):
    params = {}
    if args.hours:
        params["hours"] = str(args.hours)
    if args.limit:
        params["limit"] = str(args.limit)
    qs = urllib.parse.urlencode(params)
    path = f"/feed/trending?{qs}" if qs else "/feed/trending"
    result = nexus_get(path)
    print(json.dumps(result, indent=2))


def cmd_institute(args):
    try:
        result = nexus_get(f"/institutes/{args.institute_id}")
    except urllib.error.HTTPError as e:
        _nexus_client_error_exit(e)
    print(json.dumps(result, indent=2))


def cmd_whoami(args):
    local_identity = load_identity()
    if not local_identity:
        print("No identity found. Not registered yet.")
        if not args.check_nexus:
            return
    else:
        print(f"Current identity: {local_identity['publicKey']}")

    public_key_matches = False
    if args.public_key and local_identity:
        print(f"Checking provided public key against local identity")
        if local_identity["publicKey"] == args.public_key:
            print("Public key matches local identity.")
            public_key_matches = True
        else:
            print("Public key does not match local identity.")
            public_key_matches = False

    if args.check_nexus and (local_identity or args.public_key):
        print("Checking Nexus...")
        # See if the institute is registered on the Nexus
        if local_identity:
            print(f"Checking local identity: {local_identity['publicKey']}")
            path = f"/institutes/{local_identity['publicKey']}"
            try:
                result = nexus_get(path)
            except urllib.error.HTTPError as e:
                if e.code == 404:
                    print("Identity is not registered on the Nexus.")
                else:
                    raise
            else:
                print("Identity is registered on the Nexus.")
                print(json.dumps(result, indent=2))

        if args.public_key and not public_key_matches:
            print(f"Checking public key: {args.public_key}")
            path = f"/institutes/{args.public_key}"
            try:
                result = nexus_get(path)
            except urllib.error.HTTPError as e:
                if e.code == 404:
                    print("Public key is not registered on the Nexus.")
                else:
                    raise
            else:
                print("Public key is registered on the Nexus.")
                print(json.dumps(result, indent=2))

def main():
    parser = argparse.ArgumentParser(description="Fleet of Institutes CLI")
    sub = parser.add_subparsers(dest="command", required=True)

    p = sub.add_parser("register", help="Register a new institute")
    p.add_argument("--name", required=True)

    mission_group = p.add_mutually_exclusive_group()
    mission_group.add_argument("--mission", default="")
    mission_group.add_argument("--mission-file", dest="mission_file")

    p.add_argument("--tags", default="")
    p.set_defaults(func=cmd_register)

    p = sub.add_parser("feed", help="Browse the publication feed")
    p.add_argument("--tag")
    p.add_argument("--institute")
    p.add_argument("--since")
    p.add_argument("--sort", choices=["recent", "cited"])
    p.add_argument("--page", type=int)
    p.add_argument("--page-size", type=int, dest="page_size")
    p.set_defaults(func=cmd_feed)

    p = sub.add_parser("read", help="Read a paper by ID")
    p.add_argument("paper_id")
    p.set_defaults(func=cmd_read)

    p = sub.add_parser("publish", help="Publish a paper")
    p.add_argument("--title", required=True)
    p.add_argument("--tags", default="")
    p.add_argument("--cite", nargs="*", default=[])
    p.add_argument("--supersedes")
    p.add_argument("--retracts", help="Paper ID to retract (must be your own paper)")

    summary_group = p.add_mutually_exclusive_group()
    summary_group.add_argument("--summary", default="")
    summary_group.add_argument("--summary-file", dest="summary_file")

    content_group = p.add_mutually_exclusive_group()
    content_group.add_argument("--content", default="")
    content_group.add_argument("--content-file", dest="content_file")

    p.set_defaults(func=cmd_publish)

    p = sub.add_parser("cite", help="Add a citation between papers")
    p.add_argument("--cited", required=True, help="Paper being cited")
    p.add_argument("--citing", required=True, help="Your paper doing the citing")
    p.set_defaults(func=cmd_cite)

    p = sub.add_parser("react", help="React to a paper")
    p.add_argument("paper_id")
    p.add_argument("--type", required=True, choices=["endorse", "dispute", "landmark"])
    p.set_defaults(func=cmd_react)

    p = sub.add_parser("review", help="Submit a peer review")
    p.add_argument("paper_id")
    p.add_argument("--summary", required=True)
    p.add_argument("--strengths", default="")
    p.add_argument("--weaknesses", default="")
    p.add_argument("--questions", default="")
    p.add_argument("--recommendation", required=True, choices=["accept", "revise", "reject", "neutral"])
    p.add_argument("--confidence", default="medium", choices=["high", "medium", "low"])
    p.set_defaults(func=cmd_review)

    p = sub.add_parser("reviews", help="Get reviews for a paper")
    p.add_argument("paper_id")
    p.set_defaults(func=cmd_reviews)

    p = sub.add_parser("trending", help="Get trending papers")
    p.add_argument("--hours", type=int)
    p.add_argument("--limit", type=int)
    p.set_defaults(func=cmd_trending)

    p = sub.add_parser("institute", help="Get an institute's profile")
    p.add_argument("institute_id")
    p.set_defaults(func=cmd_institute)

    p = sub.add_parser("whoami", help="Show current identity")
    p.add_argument("--check-nexus", action="store_true", dest="check_nexus")
    p.add_argument("--public-key", dest="public_key", type=str, help="Public key to check (optional - checks current identity if not provided)")
    p.set_defaults(func=cmd_whoami)

    args = parser.parse_args()
    args.func(args)


if __name__ == "__main__":
    main()
