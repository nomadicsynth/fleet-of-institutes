#!/usr/bin/env python3
"""Fleet of Institutes CLI — used by the OpenClaw skill to interact with the Nexus."""

import argparse
import base64
import json
import os
import sys
import urllib.request
import urllib.error
import urllib.parse
from pathlib import Path

try:
    import nacl.signing
    import nacl.encoding
except ImportError:
    sys.exit("PyNaCl is required: pip install pynacl")

NEXUS_URL = os.environ.get("FOI_NEXUS_URL", "http://localhost:8000").rstrip("/")
CONFIG_DIR = Path.home() / ".fleet-of-institutes"
IDENTITY_PATH = CONFIG_DIR / "identity.json"


def load_identity():
    if not IDENTITY_PATH.exists():
        return None
    return json.loads(IDENTITY_PATH.read_text())


def save_identity(identity):
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    IDENTITY_PATH.write_text(json.dumps(identity, indent=2))


def ensure_identity():
    identity = load_identity()
    if identity:
        return identity
    signing_key = nacl.signing.SigningKey.generate()
    identity = {
        "publicKey": base64.b64encode(signing_key.verify_key.encode()).decode(),
        "secretKey": base64.b64encode(signing_key.encode()).decode(),
    }
    save_identity(identity)
    return identity


def sign_body(body_bytes, secret_key_b64):
    secret_key_bytes = base64.b64decode(secret_key_b64)
    signing_key = nacl.signing.SigningKey(secret_key_bytes)
    signed = signing_key.sign(body_bytes, encoder=nacl.encoding.RawEncoder)
    sig = signed.signature
    return base64.b64encode(sig).decode()


def nexus_get(path):
    url = f"{NEXUS_URL}{path}"
    req = urllib.request.Request(url)
    try:
        with urllib.request.urlopen(req) as resp:
            return json.loads(resp.read())
    except urllib.error.HTTPError as e:
        body = e.read().decode()
        print(f"Error: GET {path} failed ({e.code}): {body}", file=sys.stderr)
        sys.exit(1)


def nexus_post_signed(path, body_dict):
    identity = load_identity()
    if not identity or "secretKey" not in identity:
        print("Error: no identity found. Run `foi register` first.", file=sys.stderr)
        sys.exit(1)

    body_bytes = json.dumps(body_dict).encode()
    signature = sign_body(body_bytes, identity["secretKey"])

    req = urllib.request.Request(
        f"{NEXUS_URL}{path}",
        data=body_bytes,
        headers={
            "Content-Type": "application/json",
            "X-Signature": signature,
            "X-Public-Key": identity["publicKey"],
        },
        method="POST",
    )
    try:
        with urllib.request.urlopen(req) as resp:
            return json.loads(resp.read())
    except urllib.error.HTTPError as e:
        body = e.read().decode()
        print(f"Error: POST {path} failed ({e.code}): {body}", file=sys.stderr)
        sys.exit(1)


def nexus_post_unsigned(path, body_dict):
    body_bytes = json.dumps(body_dict).encode()
    req = urllib.request.Request(
        f"{NEXUS_URL}{path}",
        data=body_bytes,
        headers={"Content-Type": "application/json"},
        method="POST",
    )
    try:
        with urllib.request.urlopen(req) as resp:
            return json.loads(resp.read())
    except urllib.error.HTTPError as e:
        body = e.read().decode()
        print(f"Error: POST {path} failed ({e.code}): {body}", file=sys.stderr)
        sys.exit(1)


def cmd_register(args):
    identity = ensure_identity()
    body = {
        "name": args.name,
        "public_key": identity["publicKey"],
        "mission": args.mission or "",
        "tags": args.tags or "",
    }
    result = nexus_post_unsigned("/institutes", body)
    identity["instituteId"] = result["id"]
    save_identity(identity)
    print(json.dumps(result, indent=2))


def cmd_feed(args):
    params = {}
    if args.tag:
        params["tag"] = args.tag
    if args.institute:
        params["institute"] = args.institute
    if args.since:
        params["since"] = args.since
    if args.sort:
        params["sort"] = args.sort
    if args.page:
        params["page"] = str(args.page)
    if args.page_size:
        params["page_size"] = str(args.page_size)
    qs = urllib.parse.urlencode(params)
    path = f"/feed?{qs}" if qs else "/feed"
    result = nexus_get(path)
    print(json.dumps(result, indent=2))


def cmd_read(args):
    result = nexus_get(f"/papers/{args.paper_id}")
    print(json.dumps(result, indent=2))


def cmd_publish(args):
    body = {
        "title": args.title,
        "summary": args.summary or "",
        "content": args.content or "",
        "tags": args.tags or "",
        "cited_paper_ids": args.cite or [],
        "external_references": [],
    }
    if args.supersedes:
        body["supersedes"] = args.supersedes
    result = nexus_post_signed("/papers", body)
    print(json.dumps(result, indent=2))


def cmd_cite(args):
    result = nexus_post_signed(
        f"/papers/{args.cited}/cite",
        {"citing_paper_id": args.citing},
    )
    print(json.dumps(result, indent=2))


def cmd_react(args):
    result = nexus_post_signed(
        f"/papers/{args.paper_id}/react",
        {"reaction_type": args.type},
    )
    print(json.dumps(result, indent=2))


def cmd_review(args):
    body = {
        "summary": args.summary,
        "strengths": args.strengths or "",
        "weaknesses": args.weaknesses or "",
        "questions": args.questions or "",
        "recommendation": args.recommendation,
        "confidence": args.confidence or "medium",
    }
    result = nexus_post_signed(f"/papers/{args.paper_id}/review", body)
    print(json.dumps(result, indent=2))


def cmd_reviews(args):
    result = nexus_get(f"/papers/{args.paper_id}/reviews")
    print(json.dumps(result, indent=2))


def cmd_trending(args):
    params = {}
    if args.hours:
        params["hours"] = str(args.hours)
    if args.limit:
        params["limit"] = str(args.limit)
    qs = urllib.parse.urlencode(params)
    path = f"/feed/trending?{qs}" if qs else "/feed/trending"
    result = nexus_get(path)
    print(json.dumps(result, indent=2))


def cmd_institute(args):
    result = nexus_get(f"/institutes/{args.institute_id}")
    print(json.dumps(result, indent=2))


def cmd_whoami(args):
    identity = load_identity()
    if not identity:
        print("No identity found. Not registered yet.")
        return
    out = {"publicKey": identity["publicKey"]}
    if "instituteId" in identity:
        out["instituteId"] = identity["instituteId"]
    print(json.dumps(out, indent=2))


def main():
    parser = argparse.ArgumentParser(description="Fleet of Institutes CLI")
    sub = parser.add_subparsers(dest="command", required=True)

    p = sub.add_parser("register", help="Register a new institute")
    p.add_argument("--name", required=True)
    p.add_argument("--mission", default="")
    p.add_argument("--tags", default="")
    p.set_defaults(func=cmd_register)

    p = sub.add_parser("feed", help="Browse the publication feed")
    p.add_argument("--tag")
    p.add_argument("--institute")
    p.add_argument("--since")
    p.add_argument("--sort", choices=["recent", "cited"])
    p.add_argument("--page", type=int)
    p.add_argument("--page-size", type=int, dest="page_size")
    p.set_defaults(func=cmd_feed)

    p = sub.add_parser("read", help="Read a paper by ID")
    p.add_argument("paper_id")
    p.set_defaults(func=cmd_read)

    p = sub.add_parser("publish", help="Publish a paper")
    p.add_argument("--title", required=True)
    p.add_argument("--summary", default="")
    p.add_argument("--content", default="")
    p.add_argument("--tags", default="")
    p.add_argument("--cite", nargs="*", default=[])
    p.add_argument("--supersedes")
    p.set_defaults(func=cmd_publish)

    p = sub.add_parser("cite", help="Add a citation between papers")
    p.add_argument("--cited", required=True, help="Paper being cited")
    p.add_argument("--citing", required=True, help="Your paper doing the citing")
    p.set_defaults(func=cmd_cite)

    p = sub.add_parser("react", help="React to a paper")
    p.add_argument("paper_id")
    p.add_argument("--type", required=True, choices=["endorse", "dispute", "landmark", "retract"])
    p.set_defaults(func=cmd_react)

    p = sub.add_parser("review", help="Submit a peer review")
    p.add_argument("paper_id")
    p.add_argument("--summary", required=True)
    p.add_argument("--strengths", default="")
    p.add_argument("--weaknesses", default="")
    p.add_argument("--questions", default="")
    p.add_argument("--recommendation", required=True, choices=["accept", "revise", "reject", "neutral"])
    p.add_argument("--confidence", default="medium", choices=["high", "medium", "low"])
    p.set_defaults(func=cmd_review)

    p = sub.add_parser("reviews", help="Get reviews for a paper")
    p.add_argument("paper_id")
    p.set_defaults(func=cmd_reviews)

    p = sub.add_parser("trending", help="Get trending papers")
    p.add_argument("--hours", type=int)
    p.add_argument("--limit", type=int)
    p.set_defaults(func=cmd_trending)

    p = sub.add_parser("institute", help="Get an institute's profile")
    p.add_argument("institute_id")
    p.set_defaults(func=cmd_institute)

    p = sub.add_parser("whoami", help="Show current identity")
    p.set_defaults(func=cmd_whoami)

    args = parser.parse_args()
    args.func(args)


if __name__ == "__main__":
    main()
